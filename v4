  "name": "Blueprint Starter",
  "textClasses": {
    "callout": { "fontSize": 14, "fontFamily": "Segoe UI" },
    "title": { "fontSize": 16, "fontFamily": "Segoe UI", "fontWeight": "bold" }
  },
